{
  "_comment": "Title display rules. Each key is a lowercase song title (or fragment). Rules are checked case-insensitively. 'segments' splits the title into styled spans. 'modes' = 'dark'|'light'|'both'. For segment style, use CSS inline style strings.",
  "display flex": {
    "modes": "dark",
    "segments": [
      {
        "text": "Display;",
        "style": "color:#ff1a1a;text-shadow:0 0 8px #ff0000,0 0 2px #ff4444"
      },
      {
        "text": " "
      },
      {
        "text": "Flex;",
        "style": "color:#00cfff;text-shadow:0 0 8px #00aaff,0 0 2px #00eeff"
      }
    ]
  },
  "another green world": {
    "modes": "both",
    "segments": [
      {
        "text": "Another",
        "style": "font-style:italic"
      },
      {
        "text": " Green World"
      }
    ]
  },
  "lit(e) rail": {
    "modes": "dark",
    "_comment": "The 'e' inside the parens glows as if illuminated",
    "segments": [
      {
        "text": "Lit("
      },
      {
        "text": "e",
        "style": "color:#ffe066;text-shadow:0 0 6px #ffcc00,0 0 12px #ffaa00,0 0 2px #fff8c0;font-style:italic"
      },
      {
        "text": ") Rail"
      }
    ]
  },
  "nv|d|a rays": {
    "modes": "dark",
    "_comment": "The I's are neon-lit vertical tubes (Dan Flavin CSS homage)",
    "segments": [
      {
        "text": "N"
      },
      {
        "text": "V",
        "style": "color:#76ff76;text-shadow:0 0 4px #00ff00,0 0 10px #00cc00,0 0 20px #004400"
      },
      {
        "text": "|"
      },
      {
        "text": "D"
      },
      {
        "text": "|"
      },
      {
        "text": "A",
        "style": "color:#76ff76;text-shadow:0 0 4px #00ff00,0 0 10px #00cc00,0 0 20px #004400"
      },
      {
        "text": " Rays"
      }
    ]
  },
  "she→plex": {
    "modes": "both",
    "_comment": "Arrow animates between → and ← every second. data-anim=arrow-swap triggers JS handler.",
    "segments": [
      {
        "text": "She"
      },
      {
        "text": "→",
        "style": "display:inline-block",
        "anim": "arrow-swap"
      },
      {
        "text": "plex"
      }
    ]
  },
  "ɋ.bits": {
    "modes": "both",
    "_comment": "The ɋ is replaced by one of 4 Q-variants chosen randomly at load time. Handled by JS.",
    "segments": [
      {
        "text": "ɋ",
        "anim": "q-variants",
        "variants": [
          "ɋ",
          "Q",
          "Ƣ",
          "ℚ"
        ]
      },
      {
        "text": ".bits"
      }
    ]
  },
  "ascii mart": {
    "modes": "both",
    "_comment": "50% chance: title replaced with random ASCII art characters. Both [v1] and [v2] share the same random roll (keyed off session).",
    "segments": [
      {
        "text": "ASCII Mart",
        "anim": "ascii-mart"
      }
    ]
  },
  "ascii mart [v1]": {
    "modes": "both",
    "segments": [
      {
        "text": "ASCII Mart",
        "anim": "ascii-mart"
      },
      {
        "text": " [v1]"
      }
    ]
  }
}