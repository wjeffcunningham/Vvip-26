{
  "_comment": "Title display rules. Each key is a lowercase song title (or fragment). Rules are checked case-insensitively. 'segments' splits the title into styled spans. 'modes' = 'dark'|'light'|'both'. Use 'css_class' for CSS-animated effects defined in index.html.",
  "display flex": {
    "modes": "dark",
    "_comment": "Display; in red, Flex; in blue",
    "segments": [
      {
        "text": "Display;",
        "style": "color:red"
      },
      {
        "text": " "
      },
      {
        "text": "Flex;",
        "style": "color:blue"
      }
    ]
  },
  "another green world": {
    "modes": "both",
    "segments": [
      {
        "text": "Another",
        "style": "font-style:italic"
      },
      {
        "text": " Green World"
      }
    ]
  },
  "lit(e) rail": {
    "modes": "dark",
    "_comment": "Handled inline in JS — subtle off-white gauze on the 'e'. No segments needed here.",
    "segments": []
  },
  "nv|d|a rays": {
    "modes": "dark",
    "_comment": "The pipes are neon-lit vertical tubes (Dan Flavin CSS homage)",
    "segments": [
      {
        "text": "N"
      },
      {
        "text": "V"
      },
      {
        "text": "|",
        "style": "color:#76ff76;text-shadow:0 0 4px #00ff00,0 0 10px #00cc00,0 0 20px #004400"
      },
      {
        "text": "D"
      },
      {
        "text": "|",
        "style": "color:#76ff76;text-shadow:0 0 4px #00ff00,0 0 10px #00cc00,0 0 20px #004400"
      },
      {
        "text": "A"
      },
      {
        "text": " Rays"
      }
    ]
  },
  "she→plex": {
    "modes": "both",
    "_comment": "Arrow animates between → and ← every second.",
    "segments": [
      {
        "text": "She"
      },
      {
        "text": "→",
        "style": "display:inline-block",
        "anim": "arrow-swap"
      },
      {
        "text": "plex"
      }
    ]
  },
  "ɋ.bits": {
    "modes": "both",
    "_comment": "The ɋ is replaced by one of 4 Q-variants chosen randomly at load time.",
    "segments": [
      {
        "text": "ɋ",
        "anim": "q-variants",
        "variants": [
          "ɋ",
          "Q",
          "Ƣ",
          "ℚ"
        ]
      },
      {
        "text": ".bits"
      }
    ]
  },
  "ascii mart": {
    "modes": "both",
    "_comment": "50% chance: title replaced with random ASCII art characters.",
    "segments": [
      {
        "text": "ASCII Mart",
        "anim": "ascii-mart"
      }
    ]
  },
  "ascii mart [v1]": {
    "modes": "both",
    "segments": [
      {
        "text": "ASCII Mart",
        "anim": "ascii-mart"
      },
      {
        "text": " [v1]"
      }
    ]
  }
}